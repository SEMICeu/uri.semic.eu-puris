@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://data.europa.eu/m8g/hasPowerOfAttorney> a rdf:Property,
        owl:ObjectProperty ;
    rdfs:label "has power of attorney"@en ;
    rdfs:comment "The person authorised, pursuant to law or by appointment, to act on behalf of the legal entity in dealings with third parties and in legal proceedings."@en ;
    rdfs:isDefinedBy <http://data.europa.eu/m8g/> .

