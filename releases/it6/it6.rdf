      </owl:Ontology>
    </rdfs:isDefinedBy>
    <rdfs:label xml:lang="en">Benchmark</rdfs:label>
    <rdfs:comment xml:lang="en">A type of comparison between two or more resources.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/ComputerInfrastructure">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Computer Infrastructure</rdfs:label>
    <rdfs:comment xml:lang="en">The architecture that represents the set of hardware, software, network resources and services required for the operation of an IT environment.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/CostMatrix">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Cost Matrix</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/DataQuality">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Data Quality</rdfs:label>
    <rdfs:comment xml:lang="en">A measurable property of datasets, such as size, shape, statistical properties, benchmarks, and the presence of missing values.</rdfs:comment>
    <rdfs:subClassOf>
      <owl:Class rdf:about="http://data.europa.eu/it6/Measure">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Measure</rdfs:label>
      </owl:Class>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/EstimationProcedure">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Estimation Procedure</rdfs:label>
    <rdfs:comment xml:lang="en">How models should be evaluated, typically by defining specific kinds of train- and test splits.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/it6/Measure"/>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/Feature">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Feature</rdfs:label>
    <rdfs:comment xml:lang="en">The attribute or column in which a distribution is structured.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/Hardware">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Hardware</rdfs:label>
    <rdfs:comment xml:lang="en">The tangible, physical devices and components that support the operation of software applications and services.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/Prediction">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Prediction</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/PredictionFeature">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Prediction Feature</rdfs:label>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/RunCollection">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Run Collection</rdfs:label>
    <rdfs:comment xml:lang="en">A group of runs to easily refer to them and share them with others.</rdfs:comment>
    <rdfs:subClassOf>
      <owl:Class rdf:about="http://data.europa.eu/it6/Collection">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Collection</rdfs:label>
        <rdfs:comment xml:lang="en">A group of task or runs to easily refer to them and share them with others.</rdfs:comment>
      </owl:Class>
    </rdfs:subClassOf>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/Split">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Split</rdfs:label>
    <rdfs:comment xml:lang="en">Represents a partition of a distribution of data.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/Task">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Task</rdfs:label>
    <rdfs:comment xml:lang="en">A task defines specific problems to be solved using a given dataset.</rdfs:comment>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/TaskCollection">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Task Collection</rdfs:label>
    <rdfs:comment xml:lang="en">A group of tasks to easily refer to them and share them with others.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="http://data.europa.eu/it6/Collection"/>
  </owl:Class>
  <owl:Class rdf:about="http://data.europa.eu/it6/TaskType">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">Task Type</rdfs:label>
  </owl:Class>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/arrayData">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">array data</rdfs:label>
    <rdfs:comment xml:lang="en">For composite evaluation measures (e.g. per-class measures, confusion matrix), a string (JSON) representation of the evaluation.</rdfs:comment>
    <rdfs:domain>
      <owl:Class rdf:about="http://data.europa.eu/it6/Evaluation">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Evaluation</rdfs:label>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/bias">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">bias</rdfs:label>
    <rdfs:comment xml:lang="en">A description of the possible biases affecting the overall output of the model.</rdfs:comment>
    <rdfs:domain>
      <owl:Class rdf:about="http://data.europa.eu/it6/MachineLearningModel">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Machine Learning Model</rdfs:label>
        <rdfs:comment xml:lang="en">A file that has been trained to recognize certain types of patterns.</rdfs:comment>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/biasMethod">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">bias method</rdfs:label>
    <rdfs:comment xml:lang="en">A description of any methods implemented in data acquisition or processing, if any, to address the prevalence of identifiable biases in the training data.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/carbonEmitted">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">carbon emitted</rdfs:label>
    <rdfs:comment xml:lang="en">The emitted carbon.</rdfs:comment>
    <rdfs:domain>
      <owl:Class rdf:about="http://data.europa.eu/it6/EnvironmentalImpact">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Environmental Impact</rdfs:label>
        <rdfs:comment xml:lang="en">The measurable effects of activities on the environment.</rdfs:comment>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/className">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">class name</rdfs:label>
    <rdfs:domain>
      <owl:Class rdf:about="http://data.europa.eu/it6/Flow">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Flow</rdfs:label>
        <rdfs:comment xml:lang="en">A machine learning pipeline or neural architectures, or (untrained) machine learning models, such as in general.</rdfs:comment>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="http://data.europa.eu/it6/classification">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">classification</rdfs:label>
    <rdfs:comment xml:lang="en">The classification of the modality.</rdfs:comment>
    <rdfs:domain>
      <owl:Class rdf:about="http://data.europa.eu/it6/Modality">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Modality</rdfs:label>
        <rdfs:comment xml:lang="en">The distinct format of structure of input or output data.</rdfs:comment>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/collectionDate">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">collection date</rdfs:label>
    <rdfs:comment xml:lang="en">The date the data was originally collected, given by the uploader.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/collectionMethod">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">collection method</rdfs:label>
    <rdfs:comment xml:lang="en">Method used to collect the data, provided by the uploader.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/component">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">component</rdfs:label>
    <rdfs:domain>
      <owl:Class rdf:about="http://data.europa.eu/it6/Parameter">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Parameter</rdfs:label>
        <rdfs:comment xml:lang="en">The various configuration settings that are specified prior to and during training a model.</rdfs:comment>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/creationDate">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">creation date</rdfs:label>
    <rdfs:comment xml:lang="en">Date of creation of the resource.</rdfs:comment>
    <rdfs:domain rdf:resource="http://data.europa.eu/it6/Collection"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/curationMethod">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">curation method</rdfs:label>
    <rdfs:comment xml:lang="en">General description of the data processing involved in transforming the acquired data into training, testing, and validation data for the model, such as cleaning (e.g. filtering out irrelevant content such as advertisements), normalisation (e.g. tokenizing), augmentation (e.g. back-translation).</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/customName">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">custom name</rdfs:label>
    <rdfs:domain rdf:resource="http://data.europa.eu/it6/Flow"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/dataProvenance">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">data provenance</rdfs:label>
    <rdfs:comment xml:lang="en">A documented trail that accounts for the origin of the data.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Dataset"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/defaultTargetAttribute">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">default target attribute</rdfs:label>
    <rdfs:comment xml:lang="en">The primary attribute intended for analysis or processing, if applicable.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#Distribution"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/defaultValue">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">default value</rdfs:label>
    <rdfs:comment xml:lang="en">The default value of the parameter.</rdfs:comment>
    <rdfs:domain>
      <owl:Class rdf:about="http://data.europa.eu/it6/FlowParameter">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Flow Parameter</rdfs:label>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/descriptionVersion">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">description version</rdfs:label>
    <rdfs:comment xml:lang="en">Version number of the description. '1' for original version.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/ns/dcat#CatalogRecord"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/designSpecifications">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">design specifications</rdfs:label>
    <rdfs:comment xml:lang="en">A general description of the main steps or stages involved in the training process, including training methodologies and techniques, the key design choices, assumptions made and what the model is designed to optimise for, and the relevance of different parameters, as applicable.</rdfs:comment>
    <rdfs:domain rdf:resource="http://data.europa.eu/it6/MachineLearningModel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/download">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">download</rdfs:label>
    <rdfs:comment xml:lang="en">The number of downloads of the machine learning model.</rdfs:comment>
    <rdfs:domain>
      <owl:Class rdf:about="http://data.europa.eu/it6/Engagement">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Engagement</rdfs:label>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/errorMessage">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">error message</rdfs:label>
    <rdfs:domain>
      <owl:Class rdf:about="http://data.europa.eu/it6/Run">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
        <rdfs:label xml:lang="en">Run</rdfs:label>
        <rdfs:comment xml:lang="en">An evaluation of machine learning models (flows) trained on a given task.</rdfs:comment>
      </owl:Class>
    </rdfs:domain>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/evaluationEngine">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">evaluation engine id</rdfs:label>
    <rdfs:comment xml:lang="en">The engine responsible for extracting the features.</rdfs:comment>
    <rdfs:domain rdf:resource="http://www.w3.org/ns/dqv#QualityMeasurementDataset"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/evaluationResults">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">evaluation results</rdfs:label>
    <rdfs:comment xml:lang="en">A description of the evaluation against the validation dataset.</rdfs:comment>
    <rdfs:domain rdf:resource="http://data.europa.eu/it6/MachineLearningModel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/evaluationStrategies">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">evaluation strategies</rdfs:label>
    <rdfs:comment xml:lang="en">A description of the evaluation strategies used.</rdfs:comment>
    <rdfs:domain rdf:resource="http://data.europa.eu/it6/MachineLearningModel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/externalVersion">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">external version</rdfs:label>
    <rdfs:comment xml:lang="en">The version of the flow, as defined by the uploader, for reference.</rdfs:comment>
    <rdfs:domain rdf:resource="http://data.europa.eu/it6/Flow"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/fold">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">fold</rdfs:label>
    <rdfs:comment xml:lang="en">The number of the fold in the inner cross-validation.</rdfs:comment>
    <rdfs:domain rdf:resource="http://data.europa.eu/it6/Evaluation"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:ObjectProperty rdf:about="http://data.europa.eu/it6/hasDocument">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">has document</rdfs:label>
    <rdfs:comment xml:lang="en">The url or location of the document itself.</rdfs:comment>
    <rdfs:domain rdf:resource="https://linkedpaperswithcode.com/class/paper"/>
    <rdfs:range rdf:resource="http://xmlns.com/foaf/0.1/Document"/>
  </owl:ObjectProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/howToUse">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">how to use</rdfs:label>
    <rdfs:comment xml:lang="en">An explanation of how to use or deploy the model.</rdfs:comment>
    <rdfs:domain rdf:resource="http://data.europa.eu/it6/MachineLearningModel"/>
    <rdfs:range rdf:resource="http://www.w3.org/2000/01/rdf-schema#Literal"/>
  </owl:DatatypeProperty>
  <owl:DatatypeProperty rdf:about="http://data.europa.eu/it6/ignoreAttribute">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
