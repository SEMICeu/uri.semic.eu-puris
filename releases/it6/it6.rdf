  <owl:ObjectProperty rdf:about="http://data.europa.eu/it6/url">
    <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
    <rdfs:label xml:lang="en">url</rdfs:label>
    <rdfs:domain>
      <owl:Class rdf:about="http://data.europa.eu/it6/OutputFileDescription">
        <rdfs:isDefinedBy rdf:resource="http://data.europa.eu/it6"/>
