@prefix dc: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schemas: <https://schema.org/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://data.europa.eu/s1n/attribute> a owl:ObjectProperty;
  rdfs:label "attribute"@en;
  rdfs:comment """a component used to qualify and interpret observed values, e.g. units of measure, any scaling factors and metadata such as the status of the observation (e.g. estimated, provisional).
Attribute is a \"conceptual\" entity that applies to all distribution formats, e.g. in case a dataset is provided both in SDMX and in DataCube."""@en;
  rdfs:domain rdfs:Resource;
  rdfs:isDefinedBy <http://data.europa.eu/s1n>;
  rdfs:range <http://purl.org/linked-data/cube#AttributeProperty> .

<http://data.europa.eu/s1n/dimension> a owl:ObjectProperty;
  rdfs:label "dimension"@en;
  rdfs:comment """a component that identifies observations, e.g. the time to which the observation applies , or a geographic region which the observation covers.

Dimension is a\"conceptual\" entity that applies to all distribution formats, e.g. in case a dataset is provided both in SDMX and in DataCube. """@en;
  rdfs:domain rdfs:Resource;
  rdfs:isDefinedBy <http://data.europa.eu/s1n>;
  rdfs:range <http://purl.org/linked-data/cube#DimensionProperty> .

<http://data.europa.eu/s1n/numSeries> a rdf:Property;
  rdfs:label "number of data series"@en;
  rdfs:comment "number of data series contained in the dataset"@en;
  rdfs:domain rdfs:Resource;
  rdfs:isDefinedBy <http://data.europa.eu/s1n> .

<http://data.europa.eu/s1n/statUnitMeasure> a owl:ObjectProperty;
  rdfs:label "unit of measurement"@en;
  rdfs:comment """a unit of measurement of the observations in the dataset, for example Euro, square kilometre,
purchasing power standard (PPS), full-time equivalent, percentage. 
Unit of measurement is a \"conceptual\" entity that applies to all distribution formats,
e.g. in the case when a dataset is provided both in SDMX and in Data Cube."""@en;
  rdfs:domain rdfs:Resource;
  rdfs:isDefinedBy <http://data.europa.eu/s1n>;
  rdfs:range skos:Concept .

